{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "outDir": "./out",
    "lib": ["ES2020"],
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "src/extension.ts",
    "src/types.ts",
    "src/providers/**/*.ts",
    "src/markdown/**/*.ts",
    "src/webview/getWebviewHtml.ts"
  ],
  "exclude": ["node_modules", "**/*.test.ts", "src/webview/main.ts"]
}
